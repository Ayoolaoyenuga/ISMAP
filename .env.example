# Database configuration
DATABASE_URL=sqlite:///ismap.db

# JWT Security
JWT_SECRET_KEY=change_this_to_a_long_random_string

# Flask Settings
FLASK_APP=app.py
PORT=5000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5000,http://127.0.0.1:5000

# Frontend Settings (for build time)
VITE_API_URL=http://localhost:5000

# Optional recovery admins for deployment.
# Format:
# RECOVERY_ADMINS_JSON=[{"email":"admin@example.com","username":"admin","password":"change-me"}]
# RECOVERY_ADMINS_JSON=

# Optional: Slack Webhook for global alerts if needed
# (Users normally configure this in the UI)
# DEFAULT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
